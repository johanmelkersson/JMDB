@model JMDB.Models.MovieDetailsViewModel

@{
    ViewData["Title"] = Model.Movie.Title;
}

<div class="row mt-4">
    <div class="col-md-3">
        @if (!string.IsNullOrEmpty(Model.Movie.PosterUrl))
        {
            <img src="@Model.Movie.PosterUrl" alt="@Model.Movie.Title" class="img-fluid rounded" style="width:100%;" />
        }
        else
        {
            <div class="movie-poster-placeholder rounded" style="min-height:300px;">
                <span>@Model.Movie.Title</span>
            </div>
        }
    </div>

    <div class="col-md-9">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
            <div>
                <h1 class="mb-1">@Model.Movie.Title</h1>
                <span style="color: var(--text-secondary);">@Model.Movie.Genre &middot; @Model.Movie.ReleaseYear &middot; @Model.Movie.Duration min</span>
            </div>
            <div class="d-flex gap-2 align-items-center">
                @if (Model.AverageRating > 0)
                {
                    <span class="rating-badge fs-6">⭐ @Model.AverageRating</span>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-action="ToggleFavorite" method="post" class="d-inline">
                        <input type="hidden" name="movieId" value="@Model.Movie.Id" />
                        <button type="submit" class="btn btn-sm @(Model.IsFavorite ? "btn-warning" : "btn-outline-warning")">
                            @(Model.IsFavorite ? "★ Saved" : "☆ Favorite")
                        </button>
                    </form>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Movie.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Movie.Description))
        {
            <p class="mt-3" style="color: var(--text-secondary); line-height: 1.7;">@Model.Movie.Description</p>
        }

        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2">← Back to list</a>
    </div>
</div>

<hr style="border-color: var(--border-color); margin: 2rem 0;" />

<div class="row">
    <div class="col-md-8">
        <h4 class="section-title" id="review-heading">Reviews (@Model.Reviews.Count)</h4>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <p id="already-reviewed-msg" class="mb-4" style="color: var(--text-muted); @(!Model.UserHasReviewed ? "display:none;" : "")">
                You have already reviewed this movie.
            </p>
            <div class="crud-container mb-4" id="review-form" style="@(Model.UserHasReviewed ? "display:none;" : "")">
                <h6 class="mb-3">Write a review</h6>
                <form asp-action="AddReview" method="post">
                    <input type="hidden" name="movieId" value="@Model.Movie.Id" />
                    <div class="mb-3">
                        <label class="form-label">Rating (1–10)</label>
                        <input type="number" name="rating" min="1" max="10" value="7" class="form-control" style="width:100px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Review</label>
                        <textarea name="content" rows="3" class="form-control" placeholder="What did you think?"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger">Post review</button>
                </form>
            </div>
        }
        else
        {
            <p style="color: var(--text-muted);" class="mb-4">
                <a asp-controller="Account" asp-action="Login" class="text-accent">Login</a> to write a review.
            </p>
        }

        <div id="review-list">
            @if (!Model.Reviews.Any())
            {
                <p id="no-reviews-msg" style="color: var(--text-muted);">No reviews yet — be the first!</p>
            }
            else
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="crud-container mb-3" data-review-id="@review.Id">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>@review.User?.UserName</strong>
                            <div class="d-flex align-items-center gap-2">
                                <span class="rating-badge">@review.Rating / 10</span>
                                <span style="color: var(--text-muted); font-size:0.8rem;">@review.CreatedAt.ToString("MMM d, yyyy")</span>
                                @if (review.UserId == Model.CurrentUserId || User.IsInRole("Admin"))
                                {
                                    <form asp-action="DeleteReview" method="post" class="d-inline">
                                        <input type="hidden" name="reviewId" value="@review.Id" />
                                        <input type="hidden" name="movieId" value="@Model.Movie.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                                                onclick="return confirm('Delete this review?')">✕</button>
                                    </form>
                                }
                            </div>
                        </div>
                        <p class="mb-0" style="color: var(--text-secondary);">@review.Content</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        const movieId = "@Model.Movie.Id";
        const currentUser = "@User.Identity?.Name";
        const isAdmin = @User.IsInRole("Admin").ToString().ToLower();
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/review")
            .withAutomaticReconnect()
            .build();

        function getReviewCount() {
            return document.querySelectorAll("#review-list [data-review-id]").length;
        }

        function updateHeading(count) {
            const h = document.getElementById("review-heading");
            if (h) h.textContent = `Reviews (${count})`;
        }

        connection.on("NewReview", (review) => {
            const noMsg = document.getElementById("no-reviews-msg");
            if (noMsg) noMsg.remove();

            const canDelete = (review.userName === currentUser || isAdmin);
            const deleteBtn = canDelete ? `
                <form action="/Movies/DeleteReview" method="post" class="d-inline">
                    <input type="hidden" name="reviewId" value="${review.reviewId}" />
                    <input type="hidden" name="movieId" value="${movieId}" />
                    <input type="hidden" name="__RequestVerificationToken" value="${antiForgeryToken}" />
                    <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                            onclick="return confirm('Delete this review?')">✕</button>
                </form>` : "";

            const html = `
                <div class="crud-container mb-3" data-review-id="${review.reviewId}" style="border-left: 3px solid var(--accent);">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>${review.userName}</strong>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rating-badge">${review.rating} / 10</span>
                            <span style="color: var(--text-muted); font-size:0.8rem;">${review.createdAt}</span>
                            ${deleteBtn}
                        </div>
                    </div>
                    <p class="mb-0" style="color: var(--text-secondary);">${review.content}</p>
                </div>`;

            document.getElementById("review-list").insertAdjacentHTML("afterbegin", html);
            updateHeading(getReviewCount());

            if (review.userName === currentUser) {
                document.getElementById("review-form").style.display = "none";
                document.getElementById("already-reviewed-msg").style.display = "";
            }
        });

        connection.on("ReviewDeleted", (data) => {
            const card = document.querySelector(`[data-review-id="${data.reviewId}"]`);
            if (card) card.remove();

            updateHeading(getReviewCount());

            if (getReviewCount() === 0) {
                document.getElementById("review-list").innerHTML =
                    '<p id="no-reviews-msg" style="color: var(--text-muted);">No reviews yet — be the first!</p>';
            }

            if (data.userName === currentUser) {
                document.getElementById("already-reviewed-msg").style.display = "none";
                document.getElementById("review-form").style.display = "";
            }
        });

        connection.start()
            .then(() => connection.invoke("JoinMovieGroup", movieId))
            .catch(err => console.error("SignalR error:", err));
    </script>
}
