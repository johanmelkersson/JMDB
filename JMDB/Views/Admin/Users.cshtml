@model List<(JMDB.Models.ApplicationUser User, IList<string> Roles, int Reviews)>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex align-items-center justify-content-between mt-3 mb-4">
    <h2 class="section-title mb-0">Manage Users</h2>
    <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
</div>

<div class="crud-container p-0" style="overflow:hidden;">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th class="text-center">Reviews</th>
                <th>Joined</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (user, roles, reviews) in Model)
            {
                var role = roles.FirstOrDefault() ?? "—";
                var isSelf = user.UserName == User.Identity!.Name;

                <tr>
                    <td style="color:var(--text-primary);">
                        @user.UserName
                        @if (isSelf) { <span style="color:var(--text-muted); font-size:0.8rem;">(you)</span> }
                    </td>
                    <td style="color:var(--text-secondary);">@user.Email</td>
                    <td>
                        <span class="rating-badge" style="background-color: @(role == "Admin" ? "var(--accent)" : "#555");">
                            @role
                        </span>
                    </td>
                    <td class="text-center" style="color:var(--text-secondary);">@reviews</td>
                    <td style="color:var(--text-muted); font-size:0.85rem;">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @if (!isSelf)
                        {
                            <form asp-action="ToggleRole" method="post" class="d-inline">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary"
                                        onclick="return confirm('Change role for @user.UserName?')">
                                    → @(role == "Admin" ? "Member" : "Admin")
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
